#!/bin/bash

if command -v nvim &> /dev/null; then
    nvim "$@"
    exit
fi

if command -v condatainer &> /dev/null; then
    condatainer exec -o nvim nvim "$@"
    if [ $? -ne 0 ]; then
        condatainer create -n nvim nvim nodejs
        if [ $? -ne 0 ]; then
            vim "$@"
        else
            condatainer exec -o nvim nvim "$@"
        fi
    fi
else
    vim "$@"
fi
