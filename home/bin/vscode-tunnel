#!/bin/bash
#WHATIS: VS Code tunnel (no port forwarding needed) - standalone, no condatainer
# This script helps run vscode-tunnel on SLURM clusters without CondaTainer.

#region Inlined Common Functions

#region Colors & Messages
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
print_msg()  { echo -e "[MSG] $*"; }
print_info() { echo -e "[${CYAN}INFO${NC}] $*"; }
print_warn() { echo -e "[${YELLOW}WARN${NC}] $*"; }
print_error(){ echo -e "[${RED}ERR${NC}] $*" >&2; }
print_pass() { echo -e "[${GREEN}PASS${NC}] $*"; }
trap 'echo; exit 130' INT
#endregion

#region Directories
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/vscode-slurm"
HELPER_DEFAULTS_DIR="$CONFIG_DIR"
HELPER_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/vscode-slurm"
LOG_DIR="$HOME/logs"
mkdir -p "$CONFIG_DIR" "$HELPER_STATE_DIR" "$LOG_DIR"
#endregion

#region Config Functions
config_load() {
    local f="$HELPER_DEFAULTS_DIR/$1"
    if [ -f "$f" ]; then
        source "$f"
        local key
        while IFS='=' read -r key _; do
            [[ -z "$key" || "$key" =~ ^# ]] && continue
            printf -v "_CONFIG_${key}" '%s' "${!key}"
        done < "$f"
        return 0
    fi
    return 1
}

config_init() {
    local name="$1"; shift
    local f="$HELPER_DEFAULTS_DIR/$name"
    touch "$f"
    for pair in "$@"; do
        local key="${pair%%=*}"
        local val="${pair#*=}"
        grep -q "^${key}=" "$f" || printf '%s="%s"\n' "$key" "$val" >> "$f"
    done
}

config_require() {
    local name="$1"; shift
    for var in "$@"; do
        if [ -z "${!var}" ]; then
            print_error "Required config variable ${YELLOW}$var${NC} is not set."
            print_info "Please check your config file: ${BLUE}$(config_path "$name")${NC}"
            print_info "Or delete it to regenerate defaults."
            exit 1
        fi
    done
}

config_show() {
    local f="$HELPER_DEFAULTS_DIR/$1"
    echo -e "Config file: ${BLUE}$f${NC}"
    if [ -f "$f" ]; then
        echo "-------------"
        cat "$f"
    else
        echo "(no config file yet; will be created on first run)"
    fi
    exit 0
}

config_path() { echo "$HELPER_DEFAULTS_DIR/$1"; }
state_path()  { echo "$HELPER_STATE_DIR/$1"; }
#endregion

#region Prompt Functions
confirm_default_yes() {
    local prompt="$1"
    local prompt_hint="${2:-Y/n}"
    local resp
    read -p "[MSG] $prompt [$prompt_hint] " resp
    case "$resp" in
        ""|[Yy]*) return 0 ;;
        *) return 1 ;;
    esac
}
#endregion

#region Display Functions
spec_line() {
    local label="$1" var="$2"
    local val="${!var}"
    [ -z "$val" ] && return

    local arg_var="_ARG_${var}"
    local config_var="_CONFIG_${var}"
    local note=""

    if [ -z "${!arg_var:-}" ] && [ -n "${!config_var:-}" ]; then
        if [ "$val" != "${!config_var}" ]; then
            note="  (default: ${!config_var})"
        else
            note="  (default)"
        fi
    fi

    printf "[MSG]   %-4s: %b%s%b%s\n" "$label" "$BLUE" "$val" "$NC" "$note"
}

countdown() {
    local secs="${1:-3}"
    while [ "$secs" -gt 0 ]; do
        printf "\r[MSG] Press Ctrl+C to cancel %d " "$secs"
        sleep 1
        secs=$((secs - 1))
    done
    printf "\r\033[K"
}

_SPECS_SHOWN=false
#endregion

#region Job Management Functions
handle_reuse_mode() {
    local helper_name="$1"

    # CLI args given - keep state values with CLI overrides, no prompt
    if [ "${OPTIND:-1}" -gt 1 ]; then
        return
    fi

    case "${REUSE_MODE,,}" in
        always)
            print_info "Auto-reusing previous settings (REUSE_MODE=always)."
            ;;
        never)
            print_info "Not reusing previous settings (REUSE_MODE=never)."
            config_load "$helper_name"
            rm -f "$STATE_FILE"
            ;;
        *)
            if [ "${REUSE_MODE,,}" != "ask" ]; then
                print_warn "Invalid REUSE_MODE='$REUSE_MODE'. Defaulting to 'ask'."
            fi
            print_msg "Previous settings:"
            print_specs
            if confirm_default_yes "Reuse?" "Y: accept / n: defaults / Ctrl+C: cancel"; then
                _SPECS_SHOWN=true
            else
                config_load "$helper_name"
                print_msg "Using default settings:"
                print_specs
                _SPECS_SHOWN=true
            fi
            ;;
    esac
}

read_job_state() {
    local state_file="$1"
    [ ! -f "$state_file" ] && return 0

    source "$state_file"

    local status
    status=$(squeue -j "$JOB_ID" -h -o "%T" 2>/dev/null)

    case "$status" in
        PENDING) return 1 ;;
        RUNNING)
            [ -z "$NODE" ] && NODE=$(squeue -j "$JOB_ID" -h -o "%N" 2>/dev/null)
            return 2 ;;
        *) return 3 ;;
    esac
}

wait_for_job() {
    local job_id="$1"

    if [ -z "$job_id" ]; then
        print_error "Usage: wait_for_job <job_id>"
        exit 1
    fi

    JOB_LOG=""

    while true; do
        local status
        status=$(squeue -j "$job_id" -h -o "%T" 2>/dev/null)
        if [ "$status" == "RUNNING" ]; then
            sleep 2
            printf "\r\033[K"
            break
        fi
        if [ -z "$status" ]; then
            printf "\r\033[K"
            print_error "Job $job_id not found in the queue."
            local matches=()
            while IFS= read -r -d $'\0' f; do
                matches+=("$f")
            done < <(find "$LOG_DIR" -maxdepth 1 -type f -name "*${job_id}*" -print0 2>/dev/null)
            if [ ${#matches[@]} -gt 0 ]; then
                JOB_LOG="${matches[0]}"
                print_info "Please check the log: ${BLUE}$JOB_LOG${NC}"
            fi
            exit 1
        fi
        printf "\r[${CYAN}INFO${NC}] Waiting for job ${YELLOW}%s${NC} to start running. Current status: ${YELLOW}%s${NC}." "$job_id" "$status"
        sleep 5
    done

    NODE=$(squeue -j "$job_id" -h -o "%N")
    if [ -z "$NODE" ]; then
        print_error "Failed to retrieve node for job $job_id."
        local matches=()
        while IFS= read -r -d $'\0' f; do
            matches+=("$f")
        done < <(find "$LOG_DIR" -maxdepth 1 -type f -name "*${job_id}*" -print0 2>/dev/null)
        if [ ${#matches[@]} -gt 0 ]; then
            JOB_LOG="${matches[0]}"
            print_info "Please check the log: ${BLUE}$JOB_LOG${NC}"
        fi
        exit 1
    fi
    print_info "Job ${YELLOW}$job_id${NC} is now running on node ${BLUE}$NODE${NC}."
}
#endregion

#endregion Inlined Common Functions

#region Script Setup
HELPER_NAME=vscode-tunnel

DEFAULT_MACHINE_NAME=$(whoami)-$(hostname)
DEFAULT_MACHINE_NAME=${DEFAULT_MACHINE_NAME//./-}
if [ ${#DEFAULT_MACHINE_NAME} -gt 20 ]; then DEFAULT_MACHINE_NAME=${DEFAULT_MACHINE_NAME:0:20}; fi
AUTH_STATUS_FILE="$HELPER_STATE_DIR/vscode-tunnel-auth-status"

config_init $HELPER_NAME \
    NCPUS=4 \
    MEM=16G \
    TIME=12:00:00 \
    GPU= \
    AUTH=github \
    MACHINE_NAME="$DEFAULT_MACHINE_NAME" \
    REUSE_MODE=ask

config_load $HELPER_NAME
config_require $HELPER_NAME NCPUS MEM TIME AUTH MACHINE_NAME
#endregion

#region Help
print_help() {
    echo "Usage: $0 [options]"
    echo ""
    echo "Options:"
    echo "  -a <provider>   github or microsoft for authentication (default: $AUTH)"
    echo "  -n <name>       Machine name for the tunnel (default: $MACHINE_NAME)"
    echo ""
    echo "  -c <number>     Number of CPUs to allocate (default: $NCPUS)"
    echo "  -m <memory>     Total amount of memory to allocate (default: $MEM)"
    echo "  -t <time>       Time limit for the job (default: $TIME)"
    echo "  -g <gpu>        GPU resources (e.g., 1, a100:2). Use -g '' to clear"
    echo "  -v              View Mode NCPUS:1 MEM:4G TIME:02:00:00, GPU cleared"
    echo ""
    echo "  config          Show config file path and contents"
    echo ""
    echo "State  file: $(state_path $HELPER_NAME)"
    echo "Config file: $(config_path $HELPER_NAME)"
    echo "REUSE_MODE: 'always' (auto-reuse), 'ask' (prompt, default), 'never' (always use config)"
}

case $1 in
    config)         config_show $HELPER_NAME ;;
    --help|-h|help) print_help; exit 0 ;;
    *)              ;;
esac
#endregion

#region Tunnel Info
# print_tunnel_info <job_id> <auth_provider>
print_tunnel_info() {
    local job_id="$1"
    local auth_provider="$2"
    local max_wait_time=600
    local check_interval=5
    local elapsed_time=0
    local auth_instruction_printed=false

    print_info "Waiting for VS Code Tunnel to initialize..."

    while [ $elapsed_time -lt $max_wait_time ]; do
        if [ -f "$AUTH_STATUS_FILE" ]; then
            local auth_status
            auth_status=$(cat "$AUTH_STATUS_FILE")

            if [ "$auth_status" == "ERROR" ]; then
                print_error "$HELPER_NAME job (ID: ${YELLOW}$job_id${NC}) encountered an error."
                local log_file
                log_file=$(ls -t "$LOG_DIR/$HELPER_NAME-$job_id.log" 2>/dev/null | head -n 1)
                [ -n "$log_file" ] && print_info "Please check the SLURM log file: $log_file"
                print_info "If the machine name is taken, edit config at: $(config_path $HELPER_NAME)"
                return 1
            fi

            if [ "$auth_status" == "LOGIN" ]; then
                print_pass "Tunnel is ready!"
                print_info "To connect, you can either:"
                print_info "  - Use VSCode Remote - Tunnels extension"
                print_info "  - Use this link: ${BLUE}https://vscode.dev/tunnel/${MACHINE_NAME}${NC}"
                print_info "And use your ${YELLOW}$auth_provider${NC} account to connect to ${BLUE}$MACHINE_NAME${NC}"
                return 0
            fi

            if [ -n "$auth_status" ] && [ "$auth_instruction_printed" = false ]; then
                echo -e "\n[MSG] Please use the following message for authentication:"
                echo -e "${YELLOW}------------------------------------------------${NC}"
                cat "$AUTH_STATUS_FILE"
                echo -e "${YELLOW}------------------------------------------------${NC}"
                print_info "Waiting for authentication..."
                auth_instruction_printed=true
            fi
        fi
        sleep $check_interval
        elapsed_time=$((elapsed_time + check_interval))
    done
    echo -e "\n${RED}[TIMEOUT]${NC} Timed out waiting for tunnel start. Cancelling job ${YELLOW}$job_id${NC}."
    scancel "$job_id"
    return 1
}
#endregion

#region print_specs
print_specs() {
    spec_line "CPUs" NCPUS
    spec_line "MEM" MEM
    spec_line "TIME" TIME
    spec_line "GPU" GPU
    spec_line "Auth" AUTH
    spec_line "Machine Name" MACHINE_NAME
}
#endregion

#region Check Existing Jobs
_HAS_PREVIOUS_STATE=false

STATE_FILE="$HELPER_STATE_DIR/$HELPER_NAME"
read_job_state "$STATE_FILE"
case $? in
    1) # PENDING
        print_info "Found a pending $HELPER_NAME job (ID: ${YELLOW}$JOB_ID${NC})."
        wait_for_job "$JOB_ID"
        print_tunnel_info "$JOB_ID" "$AUTH"
        exit 0 ;;
    2) # RUNNING
        print_info "Found an existing $HELPER_NAME job (ID: ${YELLOW}$JOB_ID${NC}) running on node ${BLUE}$NODE${NC}."
        print_tunnel_info "$JOB_ID" "$AUTH"
        exit 0 ;;
    3) # Not running - handle reuse after arg parse
        _HAS_PREVIOUS_STATE=true
        print_info "The previous $HELPER_NAME job (ID: ${YELLOW}$JOB_ID${NC}) is no longer running."
        ;;
esac
#endregion

#region Arg Parsing
_NCPUS=$NCPUS
_MEM=$MEM
_TIME=$TIME
_GPU=$GPU

while getopts "c:m:t:g:a:n:v" opt; do
    case ${opt} in
        c ) NCPUS=$OPTARG; _NCPUS=$OPTARG; _ARG_NCPUS=1 ;;
        m ) MEM=$OPTARG; _MEM=$OPTARG; _ARG_MEM=1 ;;
        t ) TIME=$OPTARG; _TIME=$OPTARG; _ARG_TIME=1 ;;
        g ) GPU=$OPTARG; _GPU=$OPTARG; _ARG_GPU=1 ;;
        v ) NCPUS=1; MEM=4G; TIME=02:00:00; GPU=; _ARG_NCPUS=1; _ARG_MEM=1; _ARG_TIME=1; _ARG_GPU=1;
            print_info "View Mode: NCPUS=1, MEM=4G, TIME=02:00:00, GPU cleared" ;;
        a ) AUTH=$OPTARG; _ARG_AUTH=1 ;;
        n ) MACHINE_NAME=$OPTARG; _ARG_MACHINE_NAME=1 ;;
        \? ) print_help; exit 2 ;;
    esac
done
#endregion

#region Reuse
if [ "$_HAS_PREVIOUS_STATE" = true ]; then
    handle_reuse_mode "$HELPER_NAME"
fi
#endregion

#region Sanity Checks
if [ "$_SPECS_SHOWN" != true ]; then
    print_msg "Using settings:"
    print_specs
    countdown 5
fi

if [ "$AUTH" != "microsoft" ] && [ "$AUTH" != "github" ]; then
    print_error "Unsupported authentication provider: $AUTH. Use 'microsoft' or 'github'."
    exit 1
fi

# Ensure VSCode CLI
CODE_BIN="$HOME/.local/bin/code"
if ! [ -f "$CODE_BIN" ]; then
    print_info "VSCode CLI not found. Downloading..."
    ARCH=$(uname -m)
    if [ "$ARCH" == "x86_64" ]; then ARCH="linux-x64"; elif [ "$ARCH" == "aarch64" ]; then ARCH="linux-arm64"; else
        print_error "Unsupported architecture: $ARCH"
        exit 1
    fi
    wget -nv -O vscode-cli.tar.gz "https://update.code.visualstudio.com/latest/cli-$ARCH/stable"
    mkdir -p "$(dirname "$CODE_BIN")"
    tar -xzf vscode-cli.tar.gz -C "$(dirname "$CODE_BIN")" code && rm vscode-cli.tar.gz
    chmod +x "$CODE_BIN"
else
    print_info "Updating VSCode CLI..."
    [ -x "$CODE_BIN" ] && "$CODE_BIN" update >/dev/null 2>&1
fi
#endregion

#region Submit SLURM Job
# Parse GPU input (supports '1', 'h100:2', '2:h100') for SLURM --gres=gpu format
if [ -n "$GPU" ]; then
    if [[ "$GPU" == *":"* ]]; then
        PART1="${GPU%:*}"
        PART2="${GPU#*:}"
        if [[ "$PART1" =~ ^[0-9]+$ ]]; then
            GPU_SBATCH="#SBATCH --gpus-per-node=${PART2}:${PART1}"
        else
            GPU_SBATCH="#SBATCH --gpus-per-node=${PART1}:${PART2}"
        fi
    else
        GPU_SBATCH="#SBATCH --gpus-per-node=$GPU"
    fi
fi

SBATCH_SCRIPT_PATH="$LOG_DIR/$HELPER_NAME.sbatch"
printf "" > "$AUTH_STATUS_FILE"

cat <<EOT > "$SBATCH_SCRIPT_PATH"
#!/bin/bash
#SBATCH --job-name=$HELPER_NAME
#SBATCH --nodes=1
#SBATCH --cpus-per-task=$NCPUS
#SBATCH --mem=$MEM
#SBATCH --time=$TIME
${GPU_SBATCH:+$GPU_SBATCH}
#SBATCH --output=$LOG_DIR/$HELPER_NAME-%j.log

while ! grep -q "^JOB_ID=" "$STATE_FILE" 2>/dev/null; do sleep 1; done
echo "NODE=\$(hostname)" >> "$STATE_FILE"

# Check if already logged in with the same provider before attempting login
_SHOW_OUTPUT=\$($CODE_BIN tunnel user show 2>&1)
if echo "\$_SHOW_OUTPUT" | grep -qi "^logged in with provider $AUTH"; then
    echo "\$_SHOW_OUTPUT" > "$AUTH_STATUS_FILE"
else
    $CODE_BIN tunnel user logout
    $CODE_BIN tunnel user login --provider $AUTH 2>&1 | tee "$AUTH_STATUS_FILE"
fi
printf "LOGIN" > "$AUTH_STATUS_FILE"

$CODE_BIN tunnel \
    --accept-server-license-terms \
    --name $MACHINE_NAME

[ \$? -ne 0 ] && echo "ERROR" > "$AUTH_STATUS_FILE"
EOT

rm -f "$STATE_FILE"
SBATCH_OUTPUT=$(sbatch "$SBATCH_SCRIPT_PATH")
SBATCH_JOB_ID=$(echo $SBATCH_OUTPUT | awk '{print $4}')

cat > "$STATE_FILE" <<RUNSTATE
JOB_ID=$SBATCH_JOB_ID
NCPUS=$_NCPUS
MEM=$_MEM
TIME=$_TIME
GPU=$_GPU
AUTH=$AUTH
MACHINE_NAME=$MACHINE_NAME
RUNSTATE

wait_for_job "$SBATCH_JOB_ID"
rm -f "$SBATCH_SCRIPT_PATH"
print_tunnel_info "$SBATCH_JOB_ID" "$AUTH"
#endregion
